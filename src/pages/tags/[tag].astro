---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";
import { transitionNameForPath, transitionNameForTag } from "../../utils/view-transitions";

export async function getStaticPaths() {
  const allDocs = await getCollection("docs");
  const posts = allDocs.filter(
    (entry) =>
      (entry.id.startsWith("blog/") || entry.id.startsWith("log/") || entry.id.startsWith("coding-notes/")) &&
      !entry.id.endsWith("index.md")
  );

  const tags = new Set<string>();
  posts.forEach((post) => {
    if (post.data.tags) {
      post.data.tags.forEach((tag: string) => tags.add(tag));
    }
  });

  return Array.from(tags).map((tag) => {
    const filteredPosts = posts.filter((post) => post.data.tags?.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const tag = Astro.params.tag ? decodeURIComponent(Astro.params.tag) : "";
const { posts } = Astro.props;

function tagHref(value: string) {
  return `/tags/${encodeURIComponent(value)}`;
}

const timelineSectionLabels = new Map([
  ["blog", "Article"],
  ["log", "Log"],
  ["coding-notes", "Coding Notes"],
]);

const contentTimeline = posts
  .map((post) => {
    const sectionSlug = post.id.split("/")[0];
    const sectionIndex = ["blog", "log", "coding-notes"].includes(sectionSlug)
      ? ["blog", "log", "coding-notes"].indexOf(sectionSlug)
      : 3;
    return {
      post,
      section: timelineSectionLabels.get(sectionSlug) || sectionSlug,
      sectionSlug,
      sectionLevel: (sectionIndex % 4) + 1,
    };
  })
  .sort((a, b) => {
    const dateA = a.post.data.date ? new Date(a.post.data.date).getTime() : 0;
    const dateB = b.post.data.date ? new Date(b.post.data.date).getTime() : 0;
    return dateB - dateA;
  });
---

<StarlightPage frontmatter={{ title: `Tag: #${tag}` }} hasSidebar={true}>
  <div class="home-dashboard">
    <section class="home-card home-card--timeline">
      <div class="home-card-head">
        <div class="home-card-head-left">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          <span transition:name={transitionNameForTag(tag)}>Posts tagged with #{tag}</span>
        </div>
      </div>
      <div class="home-card-body" style="max-height: 800px; overflow-y: auto;">
        <div class="home-timeline">
          {
            contentTimeline.map(({ post, section, sectionSlug, sectionLevel }) => (
              <div class="home-timeline-item">
                <div class="home-timeline-marker" data-level={sectionLevel} />
                <div class="home-timeline-content">
                  <div class="home-timeline-meta">
                    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                      <span class="home-timeline-section" data-section={sectionSlug} data-level={sectionLevel}>
                        {section}
                      </span>
                      {post.data.tags &&
                        post.data.tags.map((t: string) => (
                          <a href={tagHref(t)} class="home-timeline-tag" style="position: relative; z-index: 2;">#{t}</a>
                        ))}
                    </div>
                    <time>{post.data.date ? new Date(post.data.date).toISOString().slice(0, 10) : ""}</time>
                  </div>
                  <div class="home-timeline-title">
                    <a
                      href={`/${post.id}`}
                      class="home-timeline-title-link"
                      transition:name={transitionNameForPath(post.id)}
                    >
                      {post.data.title}
                    </a>
                  </div>
                  {post.data.description && <div class="home-timeline-desc">{post.data.description}</div>}
                </div>
              </div>
            ))
          }
          {contentTimeline.length === 0 && <p style="padding: 1rem; color: var(--sl-color-gray-4);">No posts found.</p>}
        </div>
      </div>
    </section>
  </div>

  <style is:global>
    /* Reuse the classes from index.astro */
    .home-dashboard {
      max-width: 1120px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      box-sizing: border-box;
    }
    .home-card {
      margin: 0;
      background: var(--sl-color-bg);
      border: 1px solid var(--sl-color-gray-6);
      border-radius: 1rem;
    }
    .home-card-head {
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      border-bottom: 1px solid var(--sl-color-gray-6);
    }
    .home-card-head-left {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--sl-color-white);
    }
    .home-card-head-left svg {
      color: var(--sl-color-gray-3);
    }
    .home-card-body {
      padding: 0.75rem 1rem;
    }
    .home-card-body::-webkit-scrollbar {
      width: 6px;
    }
    .home-card-body::-webkit-scrollbar-thumb {
      background: var(--sl-color-gray-5);
      border-radius: 3px;
    }
    .home-timeline {
      position: relative;
      display: flex;
      flex-direction: column;
    }
    .home-timeline::before {
      content: "";
      position: absolute;
      top: 0.4rem;
      bottom: 0.4rem;
      left: 0.36rem;
      width: 1px;
      background: var(--sl-color-gray-6);
    }
    .home-timeline-item {
      position: relative;
      display: grid;
      grid-template-columns: 1rem minmax(0, 1fr);
      gap: 0.75rem;
      padding: 0.55rem 0.6rem 0.55rem 0;
      border-radius: 0.7rem;
      text-decoration: none;
      transition: background 0.15s ease;
    }
    .home-timeline-item:hover {
      background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    }
    .home-timeline-marker {
      position: relative;
      z-index: 1;
      width: 0.72rem;
      height: 0.72rem;
      margin-top: 0.42rem;
      border-radius: 999px;
      border: 2px solid var(--sl-color-bg);
      background: var(--home-timeline-blue, #8fb2da);
      box-shadow: 0 0 0 1px var(--sl-color-gray-6);
    }
    .home-timeline-content {
      min-width: 0;
    }
    .home-timeline-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      margin-bottom: 0.25rem;
    }
    .home-timeline-meta time {
      flex-shrink: 0;
      color: var(--sl-color-gray-4);
      font-size: 0.7rem;
    }
    .home-timeline-section {
      display: inline-flex;
      align-items: center;
      min-height: 1.35rem;
      padding: 0 0.45rem;
      border-radius: 999px;
      border: 1px solid var(--sl-color-gray-6);
      background: var(--sl-color-gray-7, var(--sl-color-gray-6));
      font-size: 0.68rem;
      font-weight: 600;
    }
    .home-timeline-tag {
      font-size: 0.68rem;
      color: var(--sl-color-gray-4);
    }
    .home-timeline-title {
      color: var(--sl-color-white);
      font-size: 0.88rem;
      font-weight: 650;
      line-height: 1.35;
    }
    .home-timeline-title-link {
      color: inherit;
      text-decoration: none;
    }
    .home-timeline-title-link::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
    }
    .home-timeline-title-link:hover {
      text-decoration: underline;
    }
    .home-timeline-desc {
      margin-top: 0.18rem;
      color: var(--sl-color-gray-4);
      font-size: 0.74rem;
      line-height: 1.45;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .home-timeline-section[data-level="1"], .home-timeline-marker[data-level="1"] { color: #8fb2da; --home-timeline-blue: #8fb2da; }
    .home-timeline-section[data-level="2"], .home-timeline-marker[data-level="2"] { color: #5f8fc2; --home-timeline-blue: #5f8fc2; }
    .home-timeline-section[data-level="3"], .home-timeline-marker[data-level="3"] { color: #356b9d; --home-timeline-blue: #356b9d; }
    .home-timeline-section[data-level="4"], .home-timeline-marker[data-level="4"] { color: #16436e; --home-timeline-blue: #16436e; }
  </style>
</StarlightPage>
