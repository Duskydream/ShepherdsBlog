---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { GRADE_RULES, calculateStats, generateId, exportToMarkdown } from '../../utils/gpa.ts';

const STORAGE_KEY = 'gpa_calculator_data_v1';
const scales = ['4.0', '4.3', '5.0'];
const scaleLabels = {
  '4.0': '4.0 制（标准）',
  '4.3': '4.3 制',
  '5.0': '5.0 制',
};
---

<StarlightPage
  frontmatter={{ title: 'GPA Calculator' }}
  hasSidebar={true}
>
  <div class="gpa-page">
    <div class="gpa-toolbar">
      <div class="gpa-toolbar-left">
        <label for="gpa-scale">绩点制度</label>
        <select id="gpa-scale">
          {scales.map((s) => (
            <option value={s}>{scaleLabels[s]}</option>
          ))}
        </select>
      </div>
      <div class="gpa-toolbar-right">
        <button id="btn-import" class="btn btn-outline" title="Import JSON">Import</button>
        <button id="btn-export" class="btn btn-outline" title="Export JSON">Export</button>
        <button id="btn-export-md" class="btn btn-outline" title="Export Markdown">Export MD</button>
        <input type="file" id="file-input" accept=".json" hidden />
      </div>
    </div>

    <form id="course-form" class="gpa-form">
      <div class="form-field">
        <label for="course-name">课程名称</label>
        <input type="text" id="course-name" placeholder="如：高等数学" required />
      </div>
      <div class="form-field form-field-sm">
        <label for="course-credit">学分</label>
        <input type="number" id="course-credit" placeholder="3" min="0.5" max="20" step="0.5" required />
      </div>
      <div class="form-field form-field-sm">
        <label for="course-score">成绩</label>
        <input type="number" id="course-score" placeholder="85" min="0" max="100" step="0.1" required />
      </div>
      <button type="submit" id="btn-add" class="btn btn-primary">添加</button>
      <button type="button" id="btn-cancel" class="btn btn-ghost hidden">取消</button>
    </form>

    <div class="gpa-stats">
      <div class="stat-card">
        <span class="stat-label">总学分</span>
        <span class="stat-value" id="total-credits">0</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">课程数</span>
        <span class="stat-value" id="course-count">0</span>
      </div>
      <div class="stat-card stat-highlight">
        <span class="stat-label">综合 GPA</span>
        <span class="stat-value" id="gpa-result">0.00</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">加权平均分</span>
        <span class="stat-value" id="avg-score">0.0</span>
      </div>
    </div>

    <div class="gpa-table-section">
      <div class="gpa-table-header">
        <h2>课程列表</h2>
        <button id="btn-clear" class="btn btn-outline btn-danger">清空</button>
      </div>
      <div class="table-wrap">
        <table class="gpa-table">
          <thead>
            <tr>
              <th>课程名称</th>
              <th>学分</th>
              <th>成绩</th>
              <th>等级</th>
              <th>绩点</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="course-list">
            <tr id="empty-row">
              <td colspan="6" class="empty-cell">暂无课程</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <details class="gpa-reference">
      <summary>绩点对照表</summary>
      <div class="table-wrap">
        <table class="gpa-table grade-table">
          <thead>
            <tr>
              <th>百分制</th>
              <th>等级</th>
              <th>4.0 制</th>
              <th>4.3 制</th>
              <th>5.0 制</th>
            </tr>
          </thead>
          <tbody>
            {GRADE_RULES.map((rule) => (
              <tr>
                <td>{rule.min}-{rule.max}</td>
                <td>{rule.grade}</td>
                <td>{rule.gp['4.0']}</td>
                <td>{rule.gp['4.3']}</td>
                <td>{rule.gp['5.0']}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </details>
  </div>

  <script define:vars={{ STORAGE_KEY }}>
    import { getGradeInfo, calculateStats, generateId, exportToMarkdown } from '../../utils/gpa.ts';

    let courses = [];
    let editingId = null;
    let currentScale = '4.0';

    const scaleSelect = document.getElementById('gpa-scale');
    const form = document.getElementById('course-form');
    const nameInput = document.getElementById('course-name');
    const creditInput = document.getElementById('course-credit');
    const scoreInput = document.getElementById('course-score');
    const btnAdd = document.getElementById('btn-add');
    const btnCancel = document.getElementById('btn-cancel');
    const btnClear = document.getElementById('btn-clear');
    const btnImport = document.getElementById('btn-import');
    const btnExport = document.getElementById('btn-export');
    const btnExportMd = document.getElementById('btn-export-md');
    const fileInput = document.getElementById('file-input');
    const courseList = document.getElementById('course-list');
    const emptyRow = document.getElementById('empty-row');

    function saveData() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ courses, scale: currentScale, updatedAt: Date.now() }));
      } catch { /* ignore */ }
    }

    function loadData() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
          const data = JSON.parse(raw);
          courses = data.courses || [];
          currentScale = data.scale || '4.0';
          scaleSelect.value = currentScale;
        }
      } catch { /* ignore */ }
    }

    function render() {
      const stats = calculateStats(courses, currentScale);
      document.getElementById('total-credits').textContent = stats.totalCredits.toFixed(1);
      document.getElementById('course-count').textContent = String(stats.courseCount);
      document.getElementById('gpa-result').textContent = stats.gpa.toFixed(2);
      document.getElementById('avg-score').textContent = stats.avgScore.toFixed(1);

      courseList.innerHTML = '';
      if (!courses.length) {
        courseList.appendChild(emptyRow);
        return;
      }

      for (const course of courses) {
        const { grade, gp } = getGradeInfo(course.score, currentScale);
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td class="course-name">${escapeHtml(course.name)}</td>
          <td class="text-center">${course.credit}</td>
          <td class="text-center">${course.score}</td>
          <td class="text-center"><span class="badge">${grade}</span></td>
          <td class="text-center fw-bold">${gp.toFixed(1)}</td>
          <td class="text-center">
            <button class="btn-icon" data-action="edit" data-id="${course.id}" title="Edit">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </button>
            <button class="btn-icon btn-icon-danger" data-action="delete" data-id="${course.id}" title="Delete">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            </button>
          </td>`;
        courseList.appendChild(tr);
      }
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function cancelEdit() {
      editingId = null;
      form.reset();
      btnAdd.textContent = '添加';
      btnCancel.classList.add('hidden');
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = nameInput.value.trim();
      const credit = parseFloat(creditInput.value);
      const score = parseFloat(scoreInput.value);
      if (!name || isNaN(credit) || isNaN(score)) return;

      if (editingId) {
        const idx = courses.findIndex((c) => c.id === editingId);
        if (idx !== -1) courses[idx] = { ...courses[idx], name, credit, score };
        cancelEdit();
      } else {
        courses.push({ id: generateId(), name, credit, score });
      }
      form.reset();
      saveData();
      render();
    });

    btnCancel.addEventListener('click', cancelEdit);

    courseList.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      const action = btn.dataset.action;
      const id = btn.dataset.id;
      if (action === 'edit') {
        const course = courses.find((c) => c.id === id);
        if (!course) return;
        editingId = id;
        nameInput.value = course.name;
        creditInput.value = String(course.credit);
        scoreInput.value = String(course.score);
        btnAdd.textContent = '更新';
        btnCancel.classList.remove('hidden');
        nameInput.focus();
      } else if (action === 'delete') {
        courses = courses.filter((c) => c.id !== id);
        if (editingId === id) cancelEdit();
        saveData();
        render();
      }
    });

    btnClear.addEventListener('click', () => {
      if (!courses.length) return;
      if (confirm('确定要清空所有课程吗？')) {
        courses = [];
        cancelEdit();
        saveData();
        render();
      }
    });

    scaleSelect.addEventListener('change', () => {
      currentScale = scaleSelect.value;
      saveData();
      render();
    });

    btnExport.addEventListener('click', () => {
      const blob = new Blob([JSON.stringify({ courses, scale: currentScale, exportedAt: new Date().toISOString() }, null, 2)], { type: 'application/json' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `gpa-data-${new Date().toISOString().slice(0, 10)}.json`;
      a.click();
      URL.revokeObjectURL(a.href);
    });

    btnExportMd.addEventListener('click', () => {
      if (!courses.length) { alert('暂无课程数据'); return; }
      const md = exportToMarkdown(courses, currentScale);
      const blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `gpa-成绩单-${new Date().toISOString().slice(0, 10)}.md`;
      a.click();
      URL.revokeObjectURL(a.href);
    });

    btnImport.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        try {
          const data = JSON.parse(ev.target.result);
          if (!Array.isArray(data.courses)) { alert('无效的数据格式'); return; }
          if (courses.length && !confirm('导入将覆盖现有数据，是否继续？')) return;
          courses = data.courses;
          if (data.scale) { currentScale = data.scale; scaleSelect.value = currentScale; }
          saveData();
          render();
          alert('导入成功！');
        } catch (err) { alert('解析文件失败：' + err.message); }
      };
      reader.readAsText(file);
      fileInput.value = '';
    });

    loadData();
    render();
  </script>
</StarlightPage>

<style is:global>
  .gpa-page {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .gpa-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .gpa-toolbar-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .gpa-toolbar-left label {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }

  .gpa-toolbar-left select {
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    color: var(--sl-color-white);
    font-size: 0.85rem;
  }

  .gpa-toolbar-right {
    display: flex;
    gap: 0.5rem;
  }

  .gpa-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 1rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 120px;
  }

  .form-field-sm {
    max-width: 80px;
  }

  .form-field label {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }

  .form-field input {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    color: var(--sl-color-white);
    font-size: 0.85rem;
  }

  .btn {
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    background: transparent;
    color: var(--sl-color-white);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn:hover { border-color: var(--sl-color-gray-3); }

  .btn-primary {
    background: var(--sl-color-text);
    color: var(--sl-color-text-invert);
    border-color: var(--sl-color-text);
  }

  .btn-ghost {
    border-color: transparent;
    color: var(--sl-color-gray-3);
  }

  .btn-danger { color: var(--sl-color-red); border-color: var(--sl-color-red); }
  .btn-danger:hover { background: var(--sl-color-red); color: var(--sl-color-text-invert); }

  .hidden { display: none !important; }

  .gpa-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .stat-card {
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .stat-highlight {
    background: var(--sl-color-text);
    color: var(--sl-color-text-invert);
  }

  .stat-highlight .stat-label,
  .stat-highlight .stat-value {
    color: var(--sl-color-text-invert);
  }

  .gpa-table-section {
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 1rem;
    overflow: hidden;
  }

  .gpa-table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .gpa-table-header h2 {
    margin: 0;
    font-size: 1rem;
  }

  .table-wrap { overflow-x: auto; }

  .gpa-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .gpa-table th {
    padding: 0.6rem 0.75rem;
    text-align: left;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    border-bottom: 1px solid var(--sl-color-gray-6);
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .gpa-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .gpa-table tbody tr:hover { background: var(--sl-color-gray-7, var(--sl-color-gray-6)); }

  .text-center { text-align: center; }
  .fw-bold { font-weight: 600; }

  .empty-cell {
    text-align: center;
    padding: 2rem !important;
    color: var(--sl-color-gray-4);
  }

  .badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .btn-icon {
    padding: 0.25rem;
    background: none;
    border: none;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    border-radius: 0.25rem;
  }

  .btn-icon:hover { background: var(--sl-color-gray-6); }
  .btn-icon-danger { color: var(--sl-color-red); }

  .gpa-reference {
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 1rem;
    padding: 0;
  }

  .gpa-reference summary {
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }

  .gpa-reference > .table-wrap {
    padding: 0 1rem 1rem;
  }

  @media (max-width: 768px) {
    .gpa-stats { grid-template-columns: repeat(2, 1fr); }
    .gpa-toolbar { flex-direction: column; align-items: flex-start; }
    .gpa-toolbar-right { width: 100%; }
    .gpa-toolbar-right .btn { flex: 1; text-align: center; }
    .gpa-form { flex-direction: column; }
    .form-field-sm { max-width: none; }
  }
</style>
