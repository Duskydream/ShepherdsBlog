---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{ title: 'Anime Reviews' }}
  hasSidebar={true}
>
  <div class="bangumi-page not-content">
    <div class="bangumi-shell">
      <div class="bangumi-toolbar">
        <div class="bangumi-search">
          <svg class="bangumi-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input
            type="text"
            id="bangumi-search"
            placeholder="搜索动画 / 游戏..."
            autocomplete="off"
          />
        </div>

        <div class="bangumi-filterbar">
          <div class="bangumi-filterbar-group">
            <span class="bangumi-filterbar-label">Media</span>
            <div class="bangumi-filterbar-options">
              <button type="button" data-media="anime" class="bangumi-chip is-active">动画</button>
              <button type="button" data-media="game" class="bangumi-chip">游戏</button>
            </div>
          </div>

          <span class="bangumi-filterbar-divider" aria-hidden="true"></span>

          <div class="bangumi-filterbar-group bangumi-filterbar-group-status">
            <span class="bangumi-filterbar-label">Status</span>
            <div class="bangumi-filterbar-options bangumi-filterbar-options-status">
              <button type="button" data-status="watching" class="bangumi-pill is-active">进行中</button>
              <button type="button" data-status="wish" class="bangumi-pill">待补完</button>
              <button type="button" data-status="watched" class="bangumi-pill">已完成</button>
            </div>
          </div>
        </div>
      </div>

      <div id="bangumi-meta" class="bangumi-meta" aria-live="polite"></div>

      <div id="bangumi-grid" class="bangumi-grid" aria-live="polite" aria-busy="false">
        <div class="bangumi-message is-pulse">加载中...</div>
      </div>
    </div>
  </div>

  <script is:inline data-astro-rerun>
    (function initBangumiPage() {
    const API = '/bangumi';
    const STATIC_FALLBACK = '/data/bangumi.json';
    const CACHE_KEY = 'bangumi_cache_v3';
    const CLIENT_TTL = 30 * 60 * 1000;
    const MEDIA_SUBJECT_TYPE = { anime: 2, game: 4 };
    const MEDIA_LABEL = { anime: '动画', game: '游戏' };
    const STATUS_LABEL = { watching: '进行中', wish: '待补完', watched: '已完成' };

    const state = {
      mediaType: 'anime',
      status: 'watching',
      data: { watching: [], wish: [], watched: [] },
      expanded: null,
      isFetching: false,
      fetchAbortController: null,
    };

    const search = document.getElementById('bangumi-search');
    const area = document.getElementById('bangumi-grid');
    const resultsMeta = document.getElementById('bangumi-meta');
    const mediaButtons = [...document.querySelectorAll('.bangumi-chip')];
    const statusButtons = [...document.querySelectorAll('.bangumi-pill')];
    let searchTimer;

    if (!search || !area || !resultsMeta) return;

    function escapeHTML(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function readCache() {
      try {
        const raw = localStorage.getItem(CACHE_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        if (parsed.__cachedAt && Date.now() - parsed.__cachedAt < CLIENT_TTL) {
          return {
            watching: parsed.watching || [],
            wish: parsed.wish || [],
            watched: parsed.watched || [],
          };
        }
      } catch { /* ignore */ }
      return null;
    }

    function saveCache(payload) {
      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify({ ...payload, __cachedAt: Date.now() }));
      } catch { /* ignore */ }
    }

    function normalizePayload(payload) {
      return {
        watching: Array.isArray(payload?.watching) ? payload.watching : [],
        wish: Array.isArray(payload?.wish) ? payload.wish : [],
        watched: Array.isArray(payload?.watched) ? payload.watched : [],
      };
    }

    function hasBangumiItems(payload) {
      return payload.watching.length > 0 || payload.wish.length > 0 || payload.watched.length > 0;
    }

    function renderMessage(message, tone, pulse) {
      area.innerHTML = '<div class="bangumi-message' + (tone === 'error' ? ' is-error' : '') + (pulse ? ' is-pulse' : '') + '">' + escapeHTML(message) + '</div>';
    }

    function setFetching(isFetching) {
      area.setAttribute('aria-busy', String(isFetching));
      area.dataset.fetching = String(isFetching);
    }

    async function requestJSON(url, signal) {
      const response = await fetch(url, { cache: 'no-store', signal });
      if (!response.ok) throw new Error('Request failed: ' + response.status);
      return response.json();
    }

    async function fetchData(force) {
      if (state.isFetching) return null;

      if (!force) {
        const cached = readCache();
        if (cached) {
          state.data = cached;
          render();
          return cached;
        }
      }

      state.isFetching = true;
      state.fetchAbortController = new AbortController();
      setFetching(true);

      try {
        const query = API + '?t=' + Date.now() + (force ? '&force=true' : '');
        const payload = normalizePayload(await requestJSON(query, state.fetchAbortController.signal));
        if (!hasBangumiItems(payload)) throw new Error('Empty Bangumi payload');
        state.data = payload;
        saveCache(state.data);
        render();
        return state.data;
      } catch (primaryError) {
        if (primaryError.name === 'AbortError') return null;
        try {
          const payload = normalizePayload(await requestJSON(STATIC_FALLBACK + '?t=' + Date.now(), state.fetchAbortController.signal));
          if (!hasBangumiItems(payload)) throw new Error('Empty Bangumi fallback payload');
          state.data = payload;
          saveCache(state.data);
          render();
          return state.data;
        } catch (fallbackError) {
          if (fallbackError.name === 'AbortError') return null;
          if (!state.data.watching.length && !state.data.wish.length && !state.data.watched.length) {
            renderMessage('无法加载数据，请检查网络连接后刷新页面', 'error');
          }
          return null;
        }
      } finally {
        state.isFetching = false;
        state.fetchAbortController = null;
        setFetching(false);
      }
    }

    function getFilteredList() {
      const source = state.data[state.status] || [];
      const typeFilter = MEDIA_SUBJECT_TYPE[state.mediaType];
      const keyword = search.value.toLowerCase().trim();

      return source
        .filter(item => item.subject?.type === typeFilter)
        .filter((item) => {
          if (!keyword) return true;
          const title = item.subject?.name_cn || item.subject?.name || '';
          return title.toLowerCase().includes(keyword);
        });
    }

    function updateResultsMeta(total) {
      const keyword = search.value.trim();
      const base = MEDIA_LABEL[state.mediaType] + ' · ' + STATUS_LABEL[state.status] + ' · ' + total + ' 项';
      resultsMeta.textContent = keyword ? base + ' · 关键词「' + keyword + '」' : base;
    }

    function getEmptyMessage() {
      if (search.value.trim()) return '没有找到匹配的内容';
      return '当前分类下还没有' + MEDIA_LABEL[state.mediaType] + '条目';
    }

    function renderCard(item, index) {
      const titleText = item.subject?.name_cn || item.subject?.name || '?';
      const title = escapeHTML(titleText);
      const image = item.subject?.images?.large || item.subject?.images?.common || '';
      const id = item.subject?.id || 0;
      const commentText = item.comment?.trim() || '';
      const comment = escapeHTML(commentText);
      const preview = escapeHTML(commentText.slice(0, 120) + (commentText.length > 120 ? '...' : ''));
      const airDate = escapeHTML(item.subject?.date || '');
      const open = state.expanded === id;

      return '<article class="bangumi-card' + (open ? ' is-open' : '') + '" data-card-id="' + id + '" style="--enter-index:' + index + ';">' +
        '<button type="button" class="bangumi-card-trigger" data-toggle-id="' + id + '" aria-expanded="' + open + '">' +
        '<div class="bangumi-cover">' +
        (image
          ? '<img src="' + image + '" alt="' + title + '" loading="lazy" decoding="async" />'
          : '<div class="bangumi-cover-placeholder">?</div>') +
        '</div>' +
        '<div class="bangumi-card-info">' +
        '<h3>' + title + '</h3>' +
        (airDate ? '<p class="bangumi-date">发行日期: ' + airDate + '</p>' : '') +
        (commentText
          ? '<p class="bangumi-preview">' + preview + '</p>'
          : '<p class="bangumi-preview bangumi-no-review">No review yet</p>') +
        '<span class="bangumi-toggle-hint">' +
        '<svg class="bangumi-toggle-icon' + (open ? ' rotate-180' : '') + '" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>' +
        '<span class="bangumi-toggle-text">' + (open ? '收起' : '展开详情') + '</span>' +
        '</span>' +
        '</div>' +
        '</button>' +
        '<div class="bangumi-detail' + (open ? ' is-open' : '') + '" data-detail-id="' + id + '">' +
        '<div class="bangumi-detail-inner">' +
        '<div class="bangumi-detail-panel">' +
        (commentText ? '<div class="bangumi-review-box"><p>' + comment + '</p></div>' : '') +
        '<a href="https://bgm.tv/subject/' + id + '" target="_blank" rel="noopener noreferrer" class="bangumi-link">' +
        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>' +
        '<span>View on Bangumi</span>' +
        '</a>' +
        '</div>' +
        '</div>' +
        '</div>' +
        '</article>';
    }

    function syncControls() {
      mediaButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.media === state.mediaType);
      });
      statusButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.status === state.status);
      });
    }

    function render() {
      const list = getFilteredList();
      updateResultsMeta(list.length);

      if (!list.length) {
        renderMessage(getEmptyMessage());
        return;
      }

      area.innerHTML = list.map((item, index) => renderCard(item, index)).join('');
    }

    function updateExpandedState(nextId) {
      const cards = area.querySelectorAll('[data-card-id]');
      cards.forEach((card) => {
        const cardId = Number(card.getAttribute('data-card-id'));
        const open = cardId === nextId;
        card.classList.toggle('is-open', open);
        const trigger = card.querySelector('[data-toggle-id]');
        const detail = card.querySelector('.bangumi-detail');
        const icon = card.querySelector('.bangumi-toggle-icon');
        const text = card.querySelector('.bangumi-toggle-text');
        trigger?.setAttribute('aria-expanded', String(open));
        detail?.classList.toggle('is-open', open);
        icon?.classList.toggle('rotate-180', open);
        if (text) text.textContent = open ? '收起' : '展开详情';
      });
    }

    function setMediaType(type) {
      state.mediaType = type;
      state.expanded = null;
      syncControls();
      render();
    }

    function setStatus(status) {
      state.status = status;
      state.expanded = null;
      syncControls();
      render();
    }

    mediaButtons.forEach(button => button.addEventListener('click', () => setMediaType(button.dataset.media)));
    statusButtons.forEach(button => button.addEventListener('click', () => setStatus(button.dataset.status)));

    area.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      const trigger = event.target.closest('[data-toggle-id]');
      if (!trigger) return;
      const nextId = Number(trigger.dataset.toggleId);
      state.expanded = state.expanded === nextId ? null : nextId;
      updateExpandedState(state.expanded);
    });

    search.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        state.expanded = null;
        render();
      }, 180);
    });

    (async () => {
      renderMessage('加载中...', 'muted', true);
      syncControls();
      await fetchData(true);
    })();
    
    document.addEventListener('astro:before-swap', () => {
      clearTimeout(searchTimer);
      state.fetchAbortController?.abort();
    }, { once: true });
    })();
  </script>
</StarlightPage>

<style is:global>
  .bangumi-page {
    max-width: 72rem;
    margin: 0 auto;
  }

  .bangumi-shell {
    position: relative;
    padding: 1rem 0;
  }

  .bangumi-toolbar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    padding-bottom: 1.5rem;
  }

  .bangumi-search {
    position: relative;
    width: 100%;
    max-width: 30rem;
  }

  .bangumi-search-icon {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: var(--sl-color-gray-4);
    pointer-events: none;
  }

  .bangumi-search input {
    width: 100%;
    padding: 0.75rem 0 0.75rem 2rem;
    border: none;
    border-bottom: 2px solid var(--sl-color-gray-5);
    border-radius: 0;
    background: transparent;
    color: var(--sl-color-white);
    font-size: 1rem;
    transition: border-color 0.2s ease;
  }

  .bangumi-search input:focus {
    outline: none;
    border-bottom-color: var(--sl-color-accent);
  }

  .bangumi-filterbar {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .bangumi-page :where(
    .bangumi-filterbar-group,
    .bangumi-filterbar-options,
    .bangumi-filterbar-options > *,
    .bangumi-card-trigger > *,
    .bangumi-card-info > *
  ) {
    margin-top: 0;
  }

  .bangumi-filterbar-group {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .bangumi-filterbar-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sl-color-gray-4);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .bangumi-filterbar-options {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .bangumi-filterbar-divider {
    display: none; /* Hide divider for a cleaner look */
  }

  .bangumi-chip,
  .bangumi-pill {
    appearance: none;
    background: transparent;
    border: none;
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    padding: 0.25rem 0;
    position: relative;
    transition: color 0.2s ease;
  }

  .bangumi-chip:hover,
  .bangumi-pill:hover {
    color: var(--sl-color-white);
  }

  .bangumi-chip.is-active,
  .bangumi-pill.is-active {
    color: var(--sl-color-accent);
  }

  .bangumi-chip::after,
  .bangumi-pill::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--sl-color-accent);
    transition: width 0.2s ease;
  }

  .bangumi-chip.is-active::after,
  .bangumi-pill.is-active::after {
    width: 100%;
  }

  .bangumi-meta {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--sl-color-gray-4);
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-left: 3px solid var(--sl-color-accent);
    padding-left: 0.75rem;
    text-align: left;
  }

  .bangumi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .bangumi-card {
    border-radius: 0;
    border: 1px solid var(--sl-color-gray-6);
    background: transparent;
    display: flex;
    flex-direction: column;
    animation: bangumiCardIn 0.5s ease both;
    animation-delay: calc(var(--enter-index, 0) * 45ms);
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.3s ease, box-shadow 0.3s ease, opacity 0.4s ease, filter 0.4s ease;
  }

  /* 聚光灯效应 (Spotlight Effect) */
  .bangumi-grid:has(.bangumi-card.is-open) .bangumi-card:not(.is-open) {
    opacity: 0.35;
    filter: grayscale(80%) blur(1px);
    transform: scale(0.98);
  }

  .bangumi-card:hover {
    border-color: var(--sl-color-gray-5);
    transform: translateY(-4px);
  }

  .bangumi-card.is-open {
    border-color: var(--sl-color-accent);
  }

  .bangumi-card-trigger {
    width: 100%;
    display: flex;
    gap: 1rem;
    padding: 1rem;
    align-items: stretch;
    cursor: pointer;
    background: none;
    border: none;
    text-align: left;
  }

  .bangumi-cover {
    width: 5rem;
    min-width: 5rem;
    height: 7rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-radius: 0; /* 直角边框 */
  }

  .bangumi-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bangumi-cover-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    font-family: monospace;
    font-size: 2rem;
    color: var(--sl-color-gray-5);
  }

  .bangumi-card-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .bangumi-card-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .bangumi-date {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.75rem;
    color: var(--sl-color-gray-4);
    margin: 0 0 0.5rem;
  }

  .bangumi-preview {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bangumi-no-review {
    color: var(--sl-color-gray-5);
    font-style: italic;
  }

  .bangumi-toggle-hint {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.75rem;
    color: var(--sl-color-accent);
    text-transform: uppercase;
  }

  .bangumi-toggle-icon {
    transition: transform 0.2s ease;
  }
  .bangumi-toggle-icon.rotate-180 {
    transform: rotate(180deg);
  }

  .bangumi-detail {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition: grid-template-rows 0.3s ease, opacity 0.3s ease;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .bangumi-detail.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .bangumi-detail-inner {
    overflow: hidden;
  }

  .bangumi-detail-panel {
    padding: 1.25rem;
  }

  .bangumi-review-box {
    border-left: 3px solid var(--sl-color-accent);
    padding-left: 1rem;
    margin-bottom: 1.25rem;
  }

  .bangumi-review-box p {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
    margin: 0;
    white-space: pre-wrap;
  }

  .bangumi-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-text);
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .bangumi-link:hover {
    background: var(--sl-color-text);
    color: var(--sl-color-bg);
  }

  .bangumi-message {
    padding: 3rem 1rem;
    text-align: center;
    font-family: ui-monospace, SFMono-Regular, monospace;
    color: var(--sl-color-gray-4);
    border: 1px dashed var(--sl-color-gray-6);
    grid-column: 1 / -1;
  }

  @keyframes bangumiCardIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .bangumi-filterbar {
      gap: 1rem;
    }
    .bangumi-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
