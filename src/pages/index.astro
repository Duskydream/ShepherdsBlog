---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";
import { execSync } from "node:child_process";

const USER_AVATAR = "https://pic1.imgdb.cn/item/65c1c9269f345e8d03080e8d.jpg";

const blogPosts = await getCollection("docs", (entry) => entry.id.startsWith("blog/") && entry.id !== "blog/index.md");
const logPosts = await getCollection("docs", (entry) => entry.id.startsWith("log/") && entry.id !== "log/index.md");
const codingNotePosts = await getCollection(
  "docs",
  (entry) => entry.id.startsWith("coding-notes/") && entry.id !== "coding-notes/index.md",
);

const timelineSectionOrder = ["blog", "log", "coding-notes"];
const timelineSectionLabels = new Map([
  ["blog", "Blog"],
  ["log", "Log"],
  ["coding-notes", "Coding Notes"],
]);

function labelFromSlug(slug: string) {
  return slug
    .split("-")
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

function timelineEntry(post: (typeof blogPosts)[number]) {
  const sectionSlug = post.id.split("/")[0];
  const sectionIndex = timelineSectionOrder.includes(sectionSlug)
    ? timelineSectionOrder.indexOf(sectionSlug)
    : timelineSectionOrder.length;
  return {
    post,
    section: timelineSectionLabels.get(sectionSlug) || labelFromSlug(sectionSlug),
    sectionSlug,
    sectionLevel: (sectionIndex % 4) + 1,
  };
}

const allPosts = [...blogPosts, ...logPosts, ...codingNotePosts];
const tagsSet = new Set<string>();
allPosts.forEach(post => {
  if (post.data.tags) {
    post.data.tags.forEach((tag: string) => tagsSet.add(tag));
  }
});
const allTags = Array.from(tagsSet).sort();

const contentTimeline = allPosts.map(timelineEntry)
  .sort((a, b) => {
    const dateA = a.post.data.date ? new Date(a.post.data.date).getTime() : 0;
    const dateB = b.post.data.date ? new Date(b.post.data.date).getTime() : 0;
    return dateB - dateA;
  });

type CommitDay = {
  date: string;
  count: number;
  level: number;
};

let commitDays: CommitDay[] = [];
let commitTotal = 0;
let commitRangeLabel = "";

function parseLocalDate(date: string) {
  const [year, month, day] = date.split("-").map(Number);
  return new Date(year, month - 1, day);
}

function formatDate(date: Date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");
  return `${year}-${month}-${day}`;
}

try {
  const output = execSync("git log --format=%ad --date=short", {
    cwd: process.cwd(),
    encoding: "utf-8",
    stdio: ["ignore", "pipe", "ignore"],
  });
  const dates = output.split(/\r?\n/).filter(Boolean);
  const commitCounts = new Map<string, number>();
  for (const date of dates) {
    commitCounts.set(date, (commitCounts.get(date) || 0) + 1);
  }

  const sortedDates = [...commitCounts.keys()].sort();
  if (sortedDates.length > 0) {
    const firstDate = parseLocalDate(sortedDates[0]);
    const lastDate = parseLocalDate(sortedDates[sortedDates.length - 1]);
    const startDate = new Date(firstDate);
    startDate.setDate(startDate.getDate() - startDate.getDay());
    const endDate = new Date(lastDate);
    endDate.setDate(endDate.getDate() + (6 - endDate.getDay()));

    const maxCount = Math.max(...commitCounts.values());
    for (const day = new Date(startDate); day <= endDate; day.setDate(day.getDate() + 1)) {
      const date = formatDate(day);
      const count = commitCounts.get(date) || 0;
      const level = count === 0 ? 0 : Math.max(1, Math.ceil((count / maxCount) * 4));
      commitDays.push({ date, count, level });
      commitTotal += count;
    }

    commitRangeLabel = `${sortedDates[0]} - ${sortedDates[sortedDates.length - 1]}`;
  }
} catch {
  commitDays = [];
}
