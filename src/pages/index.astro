---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";
import fs from "node:fs/promises";
import path from "node:path";

const USER_AVATAR = "https://pic1.imgdb.cn/item/65c1c9269f345e8d03080e8d.jpg";

type WatchingAnimeItem = {
  subject?: {
    name_cn?: string;
    name?: string;
    short_summary?: string;
  };
};

// Fetch latest blogs
const blogPosts = await getCollection("docs", (entry) => entry.id.startsWith("blog/") && entry.id !== "blog/index.md");
const latestBlogs = blogPosts
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

// Fetch latest logs
const logPosts = await getCollection("docs", (entry) => entry.id.startsWith("log/") && entry.id !== "log/index.md");
const latestLogs = logPosts
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const latestBlogLink = latestBlogs[0] ? `/${latestBlogs[0].id}` : "/blog";
const latestLogLink = latestLogs[0] ? `/${latestLogs[0].id}` : "/log";

// Fetch bangumi data
let watchingAnime: WatchingAnimeItem[] = [];
try {
  const bangumiPath = path.resolve("public/data/bangumi.json");
  const bangumiContent = await fs.readFile(bangumiPath, "utf-8");
  const bangumiData = JSON.parse(bangumiContent) as {
    watching?: WatchingAnimeItem[];
  };
  watchingAnime = (bangumiData.watching || []).slice(0, 3);
} catch {
  watchingAnime = [];
}
---

