                  x1="2"
                  y1="7"
                  x2="7"
                  y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"
                ></line><line x1="17" y1="7" x2="22" y2="7"></line></svg
              >
