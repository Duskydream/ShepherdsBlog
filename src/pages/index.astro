            </div>
            <a href={latestLogLink} class="home-card-more">
              <span>View all</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
