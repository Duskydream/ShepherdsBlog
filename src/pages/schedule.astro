                  <input type="number" id="set-weekcount" class="input input-bordered w-full" min="1" max="30" value="${state.config.weekCount}" />
                </div>
                <div>
                  <label class="label"><span class="label-text">当前周</span></label>
                  <input type="number" id="set-current" class="input input-bordered w-full" min="1" max="30" value="${state.config.currentWeek}" />
                </div>
              </div>
            </div>
            <div class="flex justify-end gap-2 mt-4">
              <button onclick="closeModal(this)" class="btn btn-ghost">取消</button>
              <button onclick="saveSettings()" class="btn btn-primary">保存</button>
            </div>
          </div>
        `,
          "max-w-md",
        );
      };

      window.saveSettings = () => {
        state.config.name = document.getElementById("set-name").value.trim() || "我的课表";
        state.config.semester = document.getElementById("set-semester").value.trim();
        state.config.startDate = document.getElementById("set-start").value;
        state.config.weekCount = Number(document.getElementById("set-weekcount").value) || 20;
        state.config.currentWeek = Number(document.getElementById("set-current").value) || 1;
        saveConfig();
        render();
        document.querySelector(".modal-overlay")?.remove();
      };

      window.exportSchedule = () => {
        const blob = new Blob([JSON.stringify(state.config, null, 2)], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${state.config.name || "schedule"}.json`;
        a.click();
        URL.revokeObjectURL(url);
      };

      window.importSchedule = (event) => {
        const file = event.target.files?.[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (e) => {
          try {
            state.config = normalizeConfig(JSON.parse(String(e.target?.result || "{}")));
            saveConfig();
            render();
            alert("导入成功");
          } catch (error) {
            alert(`导入失败：${error.message || "格式错误"}`);
          }
        };
        reader.readAsText(file);
      };

      window.clearAllCourses = () => {
        if (!confirm(`确定要清空所有课程吗？\n\n当前共有 ${state.config.courses.length} 门课程，此操作不可恢复。`)) {
          return;
        }
        state.config.courses = [];
        saveConfig();
        render();
        alert("已清空所有课程");
      };

      window.showAIModal = () => {
        const modal = showModal(`
          <div class="p-6 max-w-3xl">
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-lg font-bold text-base-content">AI 识别课表</h3>
              <button onclick="closeModal(this)" class="btn btn-ghost btn-sm">×</button>
            </div>

            <!-- 使用提示 -->
            <div class="alert bg-base-200 border border-base-300 mb-3">
              <div class="text-sm">
                <div class="font-semibold mb-1">温馨提示</div>
                <ul class="list-disc pl-5 space-y-0.5 text-xs text-base-content/70">
                  <li><strong>务必截图截全：</strong>包括上课时间段（如"8:00-9:40"）、星期、课程名称等完整信息</li>
                  <li><strong>清晰度：</strong>确保文字清晰可读，避免模糊或反光</li>
                  <li><strong>自动适配：</strong>AI会自动提取时间段，并匹配到课表左侧时间栏</li>
                  <li><strong>手动校正：</strong>识别结果可在生成后手动编辑调整</li>
                </ul>
              </div>
            </div>

            <!-- 学期配置 -->
            <div class="rounded-lg border border-base-300 bg-base-100 p-3 mb-3">
              <div class="text-sm font-semibold mb-2">学期设置</div>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="label label-text text-xs">开学日期（第一周周一）</label>
                  <input id="ai-start-date" type="date" class="input input-bordered input-sm w-full" value="${state.config.startDate}" />
                </div>
                <div>
                  <label class="label label-text text-xs">当前是第几周</label>
                  <input id="ai-current-week" type="number" min="1" max="30" class="input input-bordered input-sm w-full" value="${state.config.currentWeek}" />
                </div>
              </div>
            </div>

            <!-- API 配置 -->
            <div class="rounded-lg border border-base-300 bg-base-100 p-3 mb-3">
              <div class="text-sm font-semibold mb-2">API 配置（本地存储，不上传服务器）</div>

              <!-- 快速配置 -->
              <div class="flex flex-wrap gap-1 mb-2">
                <button type="button" onclick="setupBailian()" class="btn btn-xs btn-outline">阿里云百炼</button>
                <button type="button" onclick="setupOpenAI()" class="btn btn-xs btn-outline">OpenAI</button>
                <button type="button" onclick="setupSiliconFlow()" class="btn btn-xs btn-outline">硅基流动</button>
                <button type="button" onclick="setupCustomAPI()" class="btn btn-xs btn-outline">自定义</button>
              </div>

              <!-- API Token -->
              <div class="mb-2">
                <label class="label label-text text-xs">API Token / Key</label>
                <div class="flex gap-2">
                  <input id="ai-token-input" type="password" class="input input-bordered input-sm flex-1" placeholder="sk-..." autocomplete="off" />
                  <button id="ai-token-save" type="button" class="btn btn-sm btn-primary">保存</button>
                  <button id="ai-token-clear" type="button" class="btn btn-sm btn-ghost">清除</button>
                </div>
              </div>

              <!-- 自定义配置（折叠） -->
              <div class="collapse collapse-arrow bg-base-200">
                <input type="checkbox" id="custom-api-toggle" />
                <div class="collapse-title text-xs font-medium py-2 min-h-0">高级配置（可选）</div>
                <div class="collapse-content px-2">
                  <div class="space-y-2">
                    <div>
                      <label class="label label-text text-xs">API 端点</label>
                      <input id="ai-base-url" type="text" class="input input-bordered input-sm w-full" placeholder="https://api.openai.com/v1" />
                    </div>
                    <div>
                      <label class="label label-text text-xs">模型名称</label>
                      <input id="ai-model" type="text" class="input input-bordered input-sm w-full" placeholder="gpt-4o-mini" />
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                      <div>
                        <label class="label label-text text-xs">Temperature (0-2)</label>
                        <input id="ai-temperature" type="number" step="0.1" min="0" max="2" class="input input-bordered input-sm w-full" placeholder="0.7" />
                      </div>
                      <div>
                        <label class="label label-text text-xs">Max Tokens</label>
                        <input id="ai-max-tokens" type="number" step="100" min="100" class="input input-bordered input-sm w-full" placeholder="2000" />
                      </div>
                    </div>
                    <button type="button" onclick="saveCustomAPIConfig()" class="btn btn-xs btn-primary w-full">保存自定义配置</button>
                  </div>
                </div>
              </div>

              <div id="ai-token-tip" class="text-xs text-base-content/60 mt-2"></div>
            </div>

            <!-- 上传区域 -->
            <div class="border-2 border-dashed border-base-300 rounded-lg p-6 text-center transition-colors" id="drop-zone">
              <div class="text-3xl mb-2">[ 图片 ]</div>
              <p class="font-medium mb-1 text-sm">拖拽图片到这里，或点击按钮上传</p>
              <p class="text-xs text-base-content/60 mb-3">支持 PNG / JPG / JPEG，建议小于 8MB</p>
              <input type="file" id="ai-input" accept="image/*" class="hidden" />
              <button type="button" onclick="this.closest('.modal-overlay').querySelector('#ai-input').click()" class="btn btn-primary btn-sm">选择图片</button>
              <p id="ai-file-info" class="text-xs text-base-content/60 mt-2"></p>
            </div>

            <div id="ai-preview" class="hidden mt-3 rounded-lg border border-base-300 bg-base-100 p-3">
              <div class="flex items-center justify-between mb-2">
                <div class="text-sm font-semibold">识别结果预览（确认后才会写入课表）</div>
                <button type="button" id="ai-preview-reset" class="btn btn-xs btn-ghost">重新识别</button>
              </div>
              <div id="ai-preview-list" class="max-h-56 overflow-auto text-xs"></div>
              <div class="flex justify-end gap-2 mt-3">
                <button type="button" id="ai-preview-cancel" class="btn btn-sm btn-ghost">取消</button>
                <button type="button" id="ai-preview-confirm" class="btn btn-sm btn-primary">确认导入</button>
              </div>
            </div>
            <div id="ai-status" class="mt-2 text-xs text-base-content/60"></div>
          </div>
        `);

        const input = modal.querySelector("#ai-input");
        const dropZone = modal.querySelector("#drop-zone");
        const fileInfo = modal.querySelector("#ai-file-info");
        const statusEl = modal.querySelector("#ai-status");
        const tokenInput = modal.querySelector("#ai-token-input");
        const tokenTip = modal.querySelector("#ai-token-tip");
        const tokenSaveBtn = modal.querySelector("#ai-token-save");
        const tokenClearBtn = modal.querySelector("#ai-token-clear");
        const startDateInput = modal.querySelector("#ai-start-date");
        const currentWeekInput = modal.querySelector("#ai-current-week");
        const previewWrap = modal.querySelector("#ai-preview");
        const previewList = modal.querySelector("#ai-preview-list");
        const previewConfirmBtn = modal.querySelector("#ai-preview-confirm");
        const previewCancelBtn = modal.querySelector("#ai-preview-cancel");
        const previewResetBtn = modal.querySelector("#ai-preview-reset");
        let pendingCourses = [];

        // 加载自定义配置到输入框
        const loadCustomConfig = () => {
          modal.querySelector("#ai-base-url").value = localStorage.getItem("frosti-schedule-api-base") || "";
          modal.querySelector("#ai-model").value = localStorage.getItem("frosti-schedule-api-model") || "";
          modal.querySelector("#ai-temperature").value = localStorage.getItem("frosti-schedule-api-temperature") || "";
          modal.querySelector("#ai-max-tokens").value = localStorage.getItem("frosti-schedule-api-max-tokens") || "";
        };
        loadCustomConfig();

        const refreshTokenTip = () => {
          const token = getLocalAIToken();
          const baseUrl = localStorage.getItem("frosti-schedule-api-base") || "";
          const model = localStorage.getItem("frosti-schedule-api-model") || "";
          if (token) {
            tokenTip.textContent = `已保存 Token | 端点: ${baseUrl || "默认"} | 模型: ${model || "默认"}`;
          } else {
            tokenTip.textContent = "未保存 Token，请先配置";
          }
        };

        tokenInput.value = getLocalAIToken();
        refreshTokenTip();

        tokenSaveBtn.addEventListener("click", () => {
          setLocalAIToken(tokenInput.value);
          tokenInput.value = getLocalAIToken();
          refreshTokenTip();
        });

        tokenClearBtn.addEventListener("click", () => {
          setLocalAIToken("");
          tokenInput.value = "";
          refreshTokenTip();
        });

        const resetPreview = () => {
          pendingCourses = [];
          previewList.innerHTML = "";
          previewWrap.classList.add("hidden");
        };

        const openEditPreviewCourse = (index) => {
          const target = pendingCourses[index];
          if (!target) return;

          const editModal = showModal(
            `
            <div class="p-5">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-base font-semibold">编辑识别结果</h3>
                <button type="button" id="preview-edit-close" class="btn btn-xs btn-ghost">×</button>
              </div>
              <form id="preview-edit-form" class="space-y-2">
                <div>
                  <label class="label label-text text-xs">课程名</label>
                  <input name="name" class="input input-bordered input-sm w-full" value="${target.name || ""}" />
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div>
                    <label class="label label-text text-xs">教师</label>
                    <input name="teacher" class="input input-bordered input-sm w-full" value="${target.teacher || ""}" />
                  </div>
                  <div>
                    <label class="label label-text text-xs">地点</label>
                    <input name="location" class="input input-bordered input-sm w-full" value="${target.location || ""}" />
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div>
                    <label class="label label-text text-xs">星期</label>
                    <select name="dayOfWeek" class="select select-bordered select-sm w-full">
                      ${WEEKDAYS.map((d, i) => `<option value="${i + 1}" ${Number(target.dayOfWeek) === i + 1 ? "selected" : ""}>周${d}</option>`).join("")}
                    </select>
                  </div>
                  <div>
                    <label class="label label-text text-xs">开始节次</label>
                    <input name="periodStart" type="number" min="1" max="12" class="input input-bordered input-sm w-full" value="${target.periodStart || 1}" />
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div>
                    <label class="label label-text text-xs">持续节次</label>
                    <input name="periodCount" type="number" min="1" max="4" class="input input-bordered input-sm w-full" value="${target.periodCount || 1}" />
                  </div>
                  <div>
                    <label class="label label-text text-xs">周次类型</label>
                    <select name="weekType" class="select select-bordered select-sm w-full">
                      <option value="all" ${(target.weekType || "all") === "all" ? "selected" : ""}>每周</option>
                      <option value="odd" ${target.weekType === "odd" ? "selected" : ""}>单周</option>
                      <option value="even" ${target.weekType === "even" ? "selected" : ""}>双周</option>
                    </select>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                  <div>
                    <label class="label label-text text-xs">起始周</label>
                    <input name="weekStart" type="number" min="1" max="30" class="input input-bordered input-sm w-full" value="${target.weekStart || 1}" />
                  </div>
                  <div>
                    <label class="label label-text text-xs">结束周</label>
                    <input name="weekEnd" type="number" min="1" max="30" class="input input-bordered input-sm w-full" value="${target.weekEnd || 16}" />
                  </div>
                </div>
                <div class="flex justify-end gap-2 pt-2">
                  <button type="button" id="preview-edit-cancel" class="btn btn-sm btn-ghost">取消</button>
                  <button type="submit" class="btn btn-sm btn-primary">保存</button>
                </div>
              </form>
            </div>
          `,
            "max-w-md",
          );

          const closeEdit = () => editModal.remove();
          editModal.querySelector("#preview-edit-close")?.addEventListener("click", closeEdit);
          editModal.querySelector("#preview-edit-cancel")?.addEventListener("click", closeEdit);

          editModal.querySelector("#preview-edit-form")?.addEventListener("submit", (event) => {
            event.preventDefault();
            const fd = new FormData(event.target);

            const weekStart = Number(fd.get("weekStart") || 1);
            const weekEnd = Number(fd.get("weekEnd") || weekStart);
            const periodStart = Number(fd.get("periodStart") || 1);
            const periodCount = Number(fd.get("periodCount") || 1);
            const weekType = String(fd.get("weekType") || "all");

            if (weekEnd < weekStart) {
              alert("结束周不能小于起始周");
              return;
            }

            pendingCourses[index] = {
              ...pendingCourses[index],
              name: String(fd.get("name") || "").trim() || "未命名课程",
              teacher: String(fd.get("teacher") || "").trim() || "待确认",
              location: String(fd.get("location") || "").trim() || "待确认",
              dayOfWeek: Number(fd.get("dayOfWeek") || 1),
              periodStart: Math.max(1, periodStart),
              periodCount: Math.max(1, periodCount),
              weekStart: Math.max(1, weekStart),
              weekEnd: Math.max(1, weekEnd),
              weekType,
            };

            renderPreview(pendingCourses);
            closeEdit();
          });
        };

        const renderPreview = (courses) => {
          previewList.innerHTML = courses
            .map(
              (c, i) => `
              <div class="rounded border border-base-300 p-2 mb-2">
                <div class="flex items-center justify-between gap-2">
                  <div class="font-semibold">${i + 1}. ${c.name || "未命名课程"}</div>
                  <div class="flex items-center gap-1">
                    <button type="button" data-preview-edit="${i}" class="btn btn-xs btn-outline">编辑</button>
                    <button type="button" data-preview-delete="${i}" class="btn btn-xs btn-ghost">删除</button>
                  </div>
                </div>
                <div class="text-base-content/70 mt-1">周${WEEKDAYS[(c.dayOfWeek || 1) - 1]} · 第${c.periodStart}-${c.periodStart + c.periodCount - 1}节 · ${c.weekStart}-${c.weekEnd}周${c.weekType === "odd" ? "（单周）" : c.weekType === "even" ? "（双周）" : ""}</div>
                <div class="text-base-content/70">${c.location || "待确认"} · ${c.teacher || "待确认"}</div>
              </div>
            `,
            )
            .join("");

          previewList.querySelectorAll("[data-preview-edit]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const index = Number(btn.getAttribute("data-preview-edit"));
              openEditPreviewCourse(index);
            });
          });

          previewList.querySelectorAll("[data-preview-delete]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const index = Number(btn.getAttribute("data-preview-delete"));
              if (!Number.isFinite(index)) return;
              pendingCourses = pendingCourses.filter((_, i) => i !== index);
              if (!pendingCourses.length) {
                resetPreview();
                statusEl.textContent = "预览列表已清空，请重新识别";
                return;
              }
              renderPreview(pendingCourses);
            });
          });

          previewWrap.classList.remove("hidden");
        };

        previewConfirmBtn.addEventListener("click", () => {
          if (!pendingCourses.length) {
            statusEl.textContent = "没有可导入的课程";
            return;
          }
          state.config.courses.push(
            ...pendingCourses.map((c) => ({ ...c, id: c.id || `ai-${Date.now()}-${Math.random()}` })),
          );
          saveConfig();
          render();
          statusEl.textContent = `识别成功，已导入 ${pendingCourses.length} 门课程`;
          dropZone.innerHTML = `<div class="text-2xl mb-2">[ ✓ ]</div><p class="font-semibold text-success text-sm">导入完成</p><p class="text-xs text-base-content/60">已添加 ${pendingCourses.length} 门课程</p>`;
          resetPreview();
          setTimeout(() => modal.remove(), 1000);
        });

        previewCancelBtn.addEventListener("click", () => {
          resetPreview();
          statusEl.textContent = "已取消导入，你可以重新上传图片";
        });

        previewResetBtn.addEventListener("click", () => {
          resetPreview();
          statusEl.textContent = "请重新上传图片识别";
        });

        const runRecognition = async (file) => {
          if (!file || !file.type.startsWith("image/")) {
            statusEl.textContent = "仅支持图片文件，请重新选择";
            return;
          }
          if (file.size > 8 * 1024 * 1024) {
            statusEl.textContent = "图片过大，请控制在 8MB 以内";
            return;
          }

          // 更新学期设置
          state.config.startDate = startDateInput.value;
          state.config.currentWeek = Number(currentWeekInput.value) || 1;
          saveConfig();

          fileInfo.textContent = `已选择：${file.name}（${(file.size / 1024 / 1024).toFixed(2)} MB）`;
          dropZone.innerHTML = '<div class="text-2xl mb-2">[ ⌛ ]</div><p class="text-sm">正在识别，请稍候...</p>';
          statusEl.textContent = "识别进行中...";

          const result = await recognizeScheduleImage(file);

          if (!result?.success) {
            dropZone.innerHTML = '<div class="text-2xl mb-2">[ ✗ ]</div><p class="text-error text-sm">识别失败</p>';
            const errorMsg = result.error || "未知错误";
            const detailMsg = result.detail ? `<br><span class="text-xs opacity-75">${result.detail}</span>` : "";
            statusEl.innerHTML = `<span class="text-error">${errorMsg}${detailMsg}</span>`;
            resetPreview();
            return;
          }

          pendingCourses = Array.isArray(result.courses) ? result.courses : [];
          if (!pendingCourses.length) {
            statusEl.textContent = "识别成功，但没有可导入课程";
            return;
          }

          dropZone.innerHTML = `<div class="text-2xl mb-2">[ ✓ ]</div><p class="font-semibold text-success text-sm">识别完成</p><p class="text-xs text-base-content/60">请在下方预览后确认导入</p>`;
          statusEl.textContent = `识别完成：共 ${pendingCourses.length} 门课程，等待确认`;
          renderPreview(pendingCourses);
        };

        dropZone.addEventListener("dragover", (e) => {
          e.preventDefault();
          dropZone.classList.add("border-primary", "bg-primary/5");
        });

        dropZone.addEventListener("dragleave", () => {
          dropZone.classList.remove("border-primary", "bg-primary/5");
        });

        dropZone.addEventListener("drop", async (e) => {
          e.preventDefault();
          dropZone.classList.remove("border-primary", "bg-primary/5");
          const file = e.dataTransfer?.files?.[0];
          await runRecognition(file);
        });

        input.addEventListener("change", async (e) => {
          const file = e.target.files?.[0];
          await runRecognition(file);
        });
      };

      window.closeModal = closeModal;

      loadConfig();
      render();
    </script>
  </MainCard>
</BaseLayout>

<style is:global>
  #schedule-container::-webkit-scrollbar {
    height: 8px;
    width: 8px;
  }

  #schedule-container::-webkit-scrollbar-track {
    background: hsl(var(--b2));
    border-radius: 4px;
  }

  #schedule-container::-webkit-scrollbar-thumb {
    background: hsl(var(--bc) / 0.25);
    border-radius: 4px;
  }

  #schedule-container::-webkit-scrollbar-thumb:hover {
    background: hsl(var(--bc) / 0.45);
  }
</style>
