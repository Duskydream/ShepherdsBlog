---
import Default from '@astrojs/starlight/components/SiteTitle.astro';
---

<div class="site-title-wrapper">
  <Default {...Astro.props} />
</div>

<style>
  .site-title-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .site-title-wrapper :global(a) {
    min-width: 0;
  }
  @media (min-width: 50rem) {
    .site-title-wrapper {
      gap: 1.5rem;
    }
  }
</style>
