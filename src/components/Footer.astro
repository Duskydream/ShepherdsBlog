---
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';

const filePath = Astro.locals.starlightRoute.entry.filePath.replaceAll('\\', '/');
const showComments = 
    filePath.startsWith('src/content/docs/blog/') ||
    filePath.startsWith('src/content/docs/log/') ||
    filePath.startsWith('src/content/docs/coding-notes/');
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<EditLink {...Astro.props} />
		<LastUpdated {...Astro.props} />
	</div>
	<Pagination {...Astro.props} />

	{
		config.credits && (
			<a class="kudos sl-flex" href="https://starlight.astro.build">
				<Icon name={'starlight'} /> {Astro.locals.t('builtWithStarlight.label')}
			</a>
		)
	}

	<div class="copyright-notice">
		Copyright &copy; {new Date().getFullYear()} Shepherd Meng.
	</div>
</footer>

{showComments && (
<div style="margin-top: 3rem; background: var(--sl-color-bg); border: 1px solid var(--sl-color-gray-6); border-radius: 1rem; overflow: hidden; transition: border-color 0.2s ease;">
  <div style="padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid var(--sl-color-gray-6); font-size: 0.85rem; font-weight: 600; color: var(--sl-color-white);">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--sl-color-gray-3)" stroke-width="2">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
    </svg>
    <span>文章评论 / Comments</span>
  </div>
  <div class="giscus-container" data-giscus-lazy style="padding: 1rem; min-height: 150px;">
    <div class="giscus-placeholder" role="status">Loading comments...</div>
  </div>
</div>
)}

<script is:inline data-astro-rerun>
  (function() {
    window.__starlightGiscusObserver?.disconnect?.();
    window.__starlightGiscusThemeObserver?.disconnect?.();

    const container = document.querySelector('.giscus-container[data-giscus-lazy]');
    if (!container) return;

    let loaded = false;

    function giscusTheme() {
      return document.documentElement.dataset.theme === 'dark' ? 'transparent_dark' : 'light';
    }

    function updateLoadedGiscusTheme() {
      const frame = container.querySelector('iframe.giscus-frame');
      frame?.contentWindow?.postMessage(
        { giscus: { setConfig: { theme: giscusTheme() } } },
        'https://giscus.app'
      );
    }

    function disconnectObserver() {
      window.__starlightGiscusObserver?.disconnect?.();
      window.__starlightGiscusObserver = undefined;
    }

    function loadGiscus() {
      if (loaded) return;
      loaded = true;
      disconnectObserver();
      container.innerHTML = '';

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'Duskydream/ShepherdsBlog');
      script.setAttribute('data-repo-id', 'R_kgDOR_rpZg');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'bottom');
      script.setAttribute('data-theme', giscusTheme());
      script.setAttribute('data-lang', 'zh-CN');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;
      container.appendChild(script);
    }

    const themeObserver = new MutationObserver(() => {
      if (loaded) updateLoadedGiscusTheme();
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    window.__starlightGiscusThemeObserver = themeObserver;

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) loadGiscus();
        },
        { rootMargin: '700px 0px' }
      );
      observer.observe(container);
      window.__starlightGiscusObserver = observer;
    } else {
      loadGiscus();
    }

    document.addEventListener(
      'astro:before-swap',
      () => {
        disconnectObserver();
        themeObserver.disconnect();
      },
      { once: true }
    );

  })();
</script>

<style>
	.sl-flex {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	@layer starlight.core {
		footer {
			flex-direction: column;
			gap: 1.5rem;
		}
		.meta {
			gap: 0.75rem 3rem;
			justify-content: space-between;
			flex-wrap: wrap;
			margin-top: 3rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
		}
		.meta > :global(p:only-child) {
			margin-inline-start: auto;
		}

		.kudos {
			align-items: center;
			gap: 0.5em;
			margin: 1.5rem auto 0;
			font-size: var(--sl-text-xs);
			text-decoration: none;
			color: var(--sl-color-gray-3);
		}
		.kudos:hover {
			color: var(--sl-color-white);
		}
		
		.copyright-notice {
			text-align: center;
			margin: 1.5rem auto;
			font-size: 0.75rem;
			color: var(--sl-color-gray-4);
			font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
			letter-spacing: 0.05em;
			text-transform: uppercase;
		}

		.giscus-placeholder {
			display: grid;
			min-height: 7rem;
			place-items: center;
			color: var(--sl-color-gray-3);
			font-size: var(--sl-text-sm);
		}
	}

	@layer starlight.components {
		.kudos :global(svg) {
			color: var(--sl-color-orange);
		}
	}
</style>
