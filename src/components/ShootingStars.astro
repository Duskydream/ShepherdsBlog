---
// Pure CSS meteors for the dark theme.
---

<div class="shooting-stars-container" transition:persist>
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>
</div>

<style>
  .shooting-stars-container {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  :global(:root[data-theme="dark"]) .shooting-stars-container {
    display: block;
  }

  .star {
    position: absolute;
    top: var(--star-top);
    left: var(--star-left);
    width: var(--star-tail);
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.95),
      rgba(255, 209, 102, 0.38) 22%,
      rgba(255, 209, 102, 0.12) 58%,
      rgba(255, 255, 255, 0)
    );
    opacity: 0;
    transform: translate3d(0, 0, 0) rotate(var(--star-angle));
    transform-origin: left center;
    animation: shooting-star-glide var(--star-duration) cubic-bezier(0.2, 0.72, 0.24, 1) infinite;
    animation-delay: var(--star-delay);
    animation-fill-mode: both;
    filter: drop-shadow(0 0 0.45rem rgba(255, 209, 102, 0.34));
    will-change: transform, opacity;
  }

  .star::after {
    content: "";
    position: absolute;
    top: 50%;
    left: -0.08rem;
    width: var(--star-size);
    height: var(--star-size);
    border-radius: 999px;
    background: #fff8d9;
    transform: translateY(-50%);
    box-shadow:
      0 0 0 0.16rem rgba(255, 209, 102, 0.08),
      0 0 0.55rem rgba(255, 209, 102, 0.55),
      0 0 1rem rgba(255, 255, 255, 0.48);
  }

  .star:nth-child(1) {
    --star-top: 10vh;
    --star-left: 88vw;
    --star-tail: clamp(4.5rem, 14vw, 11rem);
    --star-size: 0.16rem;
    --star-angle: -39deg;
    --star-travel-x: -34vw;
    --star-travel-y: 27vh;
    --star-delay: -1.3s;
    --star-duration: 12.5s;
  }

  .star:nth-child(2) {
    --star-top: 24vh;
    --star-left: 98vw;
    --star-tail: clamp(5rem, 18vw, 14rem);
    --star-size: 0.14rem;
    --star-angle: -42deg;
    --star-travel-x: -44vw;
    --star-travel-y: 34vh;
    --star-delay: 2.6s;
    --star-duration: 13.75s;
  }

  .star:nth-child(3) {
    --star-top: 42vh;
    --star-left: 78vw;
    --star-tail: clamp(3.8rem, 12vw, 9.5rem);
    --star-size: 0.15rem;
    --star-angle: -36deg;
    --star-travel-x: -28vw;
    --star-travel-y: 22vh;
    --star-delay: 7.4s;
    --star-duration: 11.5s;
  }

  .star:nth-child(4) {
    --star-top: -6vh;
    --star-left: 64vw;
    --star-tail: clamp(4rem, 13vw, 10rem);
    --star-size: 0.15rem;
    --star-angle: -40deg;
    --star-travel-x: -31vw;
    --star-travel-y: 26vh;
    --star-delay: 11.2s;
    --star-duration: 15s;
  }

  @keyframes shooting-star-glide {
    0%,
    58% {
      opacity: 0;
      transform: translate3d(0, 0, 0) rotate(var(--star-angle)) scaleX(0.62);
    }

    63% {
      opacity: 0.85;
    }

    69% {
      opacity: 0.56;
    }

    78%,
    100% {
      opacity: 0;
      transform: translate3d(var(--star-travel-x), var(--star-travel-y), 0) rotate(var(--star-angle)) scaleX(1);
    }
  }

  @media (max-width: 49.999rem) {
    .star:nth-child(3) {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shooting-stars-container {
      display: none !important;
    }
  }
</style>
