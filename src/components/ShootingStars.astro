---
// ShootingStars.astro
// Pure CSS Shooting Star Animation for Revue Starlight Dark Theme
---
<div class="shooting-stars-container" transition:persist>
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>
  <div class="star"></div>
</div>

<style>
  .shooting-stars-container {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0; /* Ensures it sits behind the main content if page has z-index */
    overflow: hidden;
  }

  /* Only display the stars when the dark theme is active */
  :global(:root[data-theme="dark"]) .shooting-stars-container {
    display: block;
  }

  .star {
    position: absolute;
    top: var(--star-top);
    left: var(--star-left);
    width: 3px;
    height: 3px;
    background: #fff;
    border-radius: 50%;
    opacity: 0;
    box-shadow:
      0 0 0 4px rgba(255, 255, 255, 0.08),
      0 0 16px rgba(255, 255, 255, 0.85);
    animation: shooting-star-sweep var(--star-duration) linear infinite;
    animation-delay: var(--star-delay);
    animation-fill-mode: both;
    will-change: transform, opacity;
  }

  /* The glowing tail of the star */
  .star::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%) rotate(-45deg);
    transform-origin: left center;
    width: clamp(7rem, 18vw, 14rem);
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.9), transparent);
  }

  /* Assign random-looking positions and delays to each star */
  .star:nth-child(1) {
    --star-top: -8vh;
    --star-left: 92vw;
    --star-delay: -1s;
    --star-duration: 6s;
  }
  .star:nth-child(2) {
    --star-top: -4vh;
    --star-left: 72vw;
    --star-delay: 2.5s;
    --star-duration: 5s;
  }
  .star:nth-child(3) {
    --star-top: 10vh;
    --star-left: 96vw;
    --star-delay: 5s;
    --star-duration: 7s;
  }
  .star:nth-child(4) {
    --star-top: -10vh;
    --star-left: 55vw;
    --star-delay: 8.5s;
    --star-duration: 6.5s;
  }

  @keyframes shooting-star-sweep {
    0% {
      transform: translate3d(0, 0, 0);
      opacity: 0;
    }
    8% {
      opacity: 0.65;
    }
    70% {
      opacity: 0.55;
    }
    100% {
      transform: translate3d(-120vw, 120vh, 0);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shooting-stars-container {
      display: none !important;
    }
  }
</style>
