---
import MobileTableOfContents from "virtual:starlight/components/MobileTableOfContents";
import MobileSiteMenu from "./MobileSiteMenu.astro";

const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="page sl-flex">
  <header class="header" transition:name="site-header" transition:animate="none">
    <slot name="header" />
  </header>
  <MobileTableOfContents />
  <MobileSiteMenu />
  {
    hasSidebar && (
      <nav
        class="sidebar print:hidden"
        aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}
        transition:name="site-sidebar"
        transition:animate="none"
      >
        <div class="mobile-sidebar-scrim" aria-hidden="true"></div>
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
</div>

<style>
  @layer starlight.core {
    .page {
      flex-direction: column;
      min-height: 100vh;
    }

    .header {
      z-index: var(--sl-z-index-navbar);
      position: fixed;
      inset-inline-start: 0;
      inset-block-start: 0;
      width: 100%;
      height: var(--sl-nav-height);
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      padding-inline-end: var(--sl-nav-pad-x);
      background-color: var(--sl-color-bg-nav);
    }

    @media (max-width: 49.999rem) {
      .header {
        z-index: 1200;
      }

    }

    :global([data-has-sidebar]) .header {
      padding-inline-end: calc(
        var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size)
      );
    }

    .sidebar-pane {
      visibility: var(--sl-sidebar-visibility, hidden);
      position: fixed;
      z-index: var(--sl-z-index-menu);
      inset-block: var(--sl-nav-height) 0;
      inset-inline-start: 0;
      width: 100%;
      background-color: var(--sl-color-black);
      overflow-y: auto;
    }

    .mobile-sidebar-scrim {
      display: none;
    }

    :global([aria-expanded="true"]) ~ .sidebar-pane,
    :global(body[data-mobile-menu-expanded]) .sidebar-pane {
      --sl-sidebar-visibility: visible;
    }

    .sidebar-content {
      height: 100%;
      min-height: max-content;
      padding: 1rem var(--sl-sidebar-pad-x) 0;
      flex-direction: column;
      gap: 1rem;
    }

    @media (min-width: 50rem) {
      .sidebar-content::after {
        content: "";
        padding-bottom: 1px;
      }
    }

    .main-frame {
      padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height));
      padding-inline-start: var(--sl-content-inline-start);
    }

    @media (min-width: 50rem) {
      :global([data-has-sidebar]) .header {
        padding-inline-end: var(--sl-nav-pad-x);
      }

      .sidebar-pane {
        --sl-sidebar-visibility: visible;
        width: var(--sl-sidebar-width);
        background-color: var(--sl-color-bg-sidebar);
        border-inline-end: 1px solid var(--sl-color-hairline-shade);
      }
    }
  }
</style>

<style is:global>
  :root {
    --sl-mobile-sidebar-bg-solid: #fff;
  }

  :root[data-theme="dark"] {
    --sl-mobile-sidebar-bg-solid: #0b0c10;
  }

  @media (max-width: 49.999rem) {
    body[data-mobile-menu-expanded] {
      overflow: hidden;
    }

    body[data-mobile-menu-expanded]::before {
      content: "";
      position: fixed;
      z-index: 1170;
      inset: var(--sl-nav-height) 0 auto;
      height: calc(100dvh - var(--sl-nav-height));
      background: var(--sl-mobile-sidebar-bg-solid);
      pointer-events: none;
    }

    body[data-mobile-menu-expanded]::after {
      opacity: 0 !important;
    }

    body[data-mobile-menu-expanded] mobile-starlight-toc {
      display: none !important;
    }

    body[data-mobile-menu-expanded] .main-frame {
      visibility: hidden !important;
      pointer-events: none;
    }

    .sidebar .mobile-sidebar-scrim {
      display: none;
    }

    body[data-mobile-menu-expanded] .sidebar .mobile-sidebar-scrim {
      display: block;
      position: fixed;
      z-index: 1180;
      inset: var(--sl-nav-height) 0 auto;
      height: calc(100dvh - var(--sl-nav-height));
      background: var(--sl-mobile-sidebar-bg-solid);
    }

    .sidebar .sidebar-pane {
      display: none;
    }

    body[data-mobile-menu-expanded] .sidebar .sidebar-pane {
      --sl-sidebar-visibility: visible;
      display: block !important;
      visibility: visible !important;
      position: fixed !important;
      z-index: 1190 !important;
      inset: var(--sl-nav-height) 0 auto !important;
      height: calc(100dvh - var(--sl-nav-height)) !important;
      width: 100% !important;
      max-width: none !important;
      border-top: 1px solid var(--sl-color-hairline-shade);
      background: var(--sl-mobile-sidebar-bg-solid) !important;
      box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.08);
      overflow-y: auto !important;
      overscroll-behavior: contain;
      contain: layout paint style;
    }

    body[data-mobile-menu-expanded] .sidebar .sidebar-content {
      min-height: 100%;
      background: inherit;
      padding: 1.75rem var(--sl-sidebar-pad-x) max(2rem, env(safe-area-inset-bottom));
    }

    body[data-mobile-menu-expanded] .sidebar .sidebar-content > * {
      position: relative;
      z-index: 1;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (() => {
    window.__mobileSidebarOverlayController?.abort?.();
    const controller = new AbortController();
    window.__mobileSidebarOverlayController = controller;

    function closeMobileMenu() {
      document.body.removeAttribute('data-mobile-menu-expanded');
      document.querySelectorAll('starlight-menu-button').forEach((button) => {
        button.setAttribute('aria-expanded', 'false');
      });
    }

    const desktopQuery = window.matchMedia('(min-width: 50rem)');
    function closeMobileMenuOnDesktop() {
      if (desktopQuery.matches) closeMobileMenu();
    }

    document.addEventListener(
      'click',
      (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (
          target.closest('.mobile-sidebar-scrim') ||
          target.closest('.mobile-site-menu-panel a') ||
          target.closest('#starlight__sidebar a')
        ) {
          closeMobileMenu();
        }
      },
      { signal: controller.signal }
    );

    document.addEventListener(
      'keydown',
      (event) => {
        if (event.key === 'Escape') closeMobileMenu();
      },
      { signal: controller.signal }
    );

    document.addEventListener('astro:before-swap', closeMobileMenu, { signal: controller.signal });
    desktopQuery.addEventListener('change', closeMobileMenuOnDesktop, { signal: controller.signal });
    closeMobileMenuOnDesktop();
  })();
</script>
