---
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import { getCollection } from 'astro:content';
import { transitionNameForPath } from '../utils/view-transitions';

const { sidebar } = Astro.locals.starlightRoute;

const docs = await getCollection('docs');
const dateByPath = new Map(
	docs
		.filter((entry) => entry.data.date instanceof Date)
		.map((entry) => [entry.id.toLowerCase(), entry.data.date!.getTime()])
);

function pathKey(href: string) {
	try {
		return decodeURIComponent(href).replace(/^\/+|\/+$/g, '').toLowerCase();
	} catch {
		return href.replace(/^\/+|\/+$/g, '').toLowerCase();
	}
}

function getEntryDate(entry: any) {
	return entry.type === 'link' ? dateByPath.get(pathKey(entry.href)) : undefined;
}

function sortEntries(entries: any[]): any[] {
	return entries
		.map((entry, index) => ({
			index,
			entry: entry.type === 'group' ? { ...entry, entries: sortEntries(entry.entries) } : entry,
		}))
		.sort((left, right) => {
			const leftDate = getEntryDate(left.entry);
			const rightDate = getEntryDate(right.entry);

			if (leftDate !== undefined && rightDate !== undefined && leftDate !== rightDate) {
				return rightDate - leftDate;
			}
			if (leftDate !== undefined && rightDate === undefined) return -1;
			if (leftDate === undefined && rightDate !== undefined) return 1;
			return left.index - right.index;
		})
		.map(({ entry }) => entry);
}

function hasCurrent(items: any[]): boolean {
	return items.some(item => item.type === 'link' ? item.isCurrent : hasCurrent(item.entries));
}

function getActiveContext(items: any[]): any[] {
	for (const item of items) {
		if (item.type === 'group' && hasCurrent(item.entries)) {
            if (item.label === 'Links') return []; // 强制隐藏 Links
			return [item];
		}
	}
	return [];
}

const contextSidebar = getActiveContext(sidebar);

// 提取所有链接为扁平结构，移除 details 折叠逻辑
const flattenedLinks: any[] = [];
let currentCategory = "";

function flatten(items: any[], isTop = true) {
    for (const item of items) {
        if (item.type === 'group') {
            if (isTop) currentCategory = item.label;
            flatten(sortEntries(item.entries), false);
        } else if (item.type === 'link') {
            flattenedLinks.push(item);
        }
    }
}
flatten(contextSidebar);

function collectLinks(items: any[]): any[] {
	return sortEntries(items).flatMap((item) => {
		if (item.type === 'link') return [item];
		if (item.type === 'group') return collectLinks(item.entries);
		return [];
	});
}

const mobileTopLinks = sidebar.filter((item: any) => item.type === 'link');
const mobileSections = [
	mobileTopLinks.length ? { label: 'Navigation', links: mobileTopLinks } : undefined,
	...sidebar
		.filter((item: any) => item.type === 'group')
		.map((item: any) => ({ label: item.label, links: collectLinks(item.entries) }))
		.filter((section: any) => section.links.length > 0),
].filter(Boolean) as { label: string; links: any[] }[];

const hasDesktopContext = flattenedLinks.length > 0;
---

<div class="desktop-sidebar-context">
	{hasDesktopContext ? (
		<SidebarPersister>
			{currentCategory && (
				<div class="sidebar-category-title">{currentCategory}</div>
			)}
			<ul class="flat-sidebar-list">
				{flattenedLinks.map(link => (
					<li>
						{
							link.isCurrent || !link.href?.startsWith('/') ? (
								<a href={link.href} aria-current={link.isCurrent ? 'page' : undefined} class={link.isCurrent ? 'active large' : 'large'}>
									<span>{link.label}</span>
								</a>
							) : (
								<a href={link.href} class="large" transition:name={transitionNameForPath(link.href)}>
									<span>{link.label}</span>
								</a>
							)
						}
					</li>
				))}
			</ul>
		</SidebarPersister>
	) : (
		<div class="desktop-sidebar-fallback">
			{mobileSections.map((section) => (
				<section class="desktop-sidebar-section">
					<h2>{section.label}</h2>
					<ul>
						{section.links.map((link) => (
							<li>
								{
									link.isCurrent || !link.href?.startsWith('/') ? (
										<a href={link.href} aria-current={link.isCurrent ? 'page' : undefined}>
											<span>{link.label}</span>
										</a>
									) : (
										<a href={link.href} transition:name={transitionNameForPath(link.href)}>
											<span>{link.label}</span>
										</a>
									)
								}
							</li>
						))}
					</ul>
				</section>
			))}
		</div>
	)}
</div>

<div class="mobile-sidebar-nav">
	{mobileSections.map((section) => (
		<section class="mobile-sidebar-section">
			<h2>{section.label}</h2>
			<ul>
				{section.links.map((link) => (
					<li>
						{
							link.isCurrent || !link.href?.startsWith('/') ? (
								<a href={link.href} aria-current={link.isCurrent ? 'page' : undefined}>
									<span>{link.label}</span>
								</a>
							) : (
								<a href={link.href} transition:name={transitionNameForPath(link.href)}>
									<span>{link.label}</span>
								</a>
							)
						}
					</li>
				))}
			</ul>
		</section>
	))}
</div>

<div class="md:sl-hidden">
	<MobileMenuFooter />
</div>

<style>
.mobile-sidebar-nav {
	display: none;
}

.desktop-sidebar-fallback {
	display: grid;
	gap: 1rem;
}

.desktop-sidebar-section h2 {
	margin: 0 0 0.4rem;
	color: var(--sl-color-text);
	font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
	font-size: 0.74rem;
	font-weight: 700;
	letter-spacing: 0.15em;
	text-transform: uppercase;
}

.desktop-sidebar-section ul {
	list-style: none;
	margin: 0;
	padding: 0;
	display: grid;
	gap: 0.12rem;
}

.desktop-sidebar-section a {
	display: block;
	border-left: 2px solid transparent;
	padding: 0.24rem 0.55rem;
	color: var(--sl-color-gray-3);
	font-size: 0.86rem;
	line-height: 1.35;
	text-decoration: none;
}

.desktop-sidebar-section a:hover,
.desktop-sidebar-section a:focus {
	color: var(--sl-color-text-accent);
}

.desktop-sidebar-section a[aria-current="page"] {
	border-left-color: var(--sl-color-accent);
	color: var(--sl-color-accent);
	font-weight: 700;
}

.sidebar-category-title {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
    font-size: 0.85rem;
    color: var(--sl-color-text);
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
}
.flat-sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}
.flat-sidebar-list a {
    display: block;
    text-decoration: none;
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
    line-height: 1.4;
    padding: 0.3rem 0;
}
.flat-sidebar-list a:hover {
    color: var(--sl-color-white);
}

@media (max-width: 49.999rem) {
	.desktop-sidebar-context {
		display: none;
	}

	.mobile-sidebar-nav {
		display: grid;
		gap: 1.35rem;
	}

	.mobile-sidebar-section h2 {
		margin: 0 0 0.55rem;
		color: var(--sl-color-text);
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Courier New", monospace;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.mobile-sidebar-section ul {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--sl-color-hairline-shade);
	}

	.mobile-sidebar-section a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border-bottom: 1px solid var(--sl-color-hairline-shade);
		padding: 0.78rem 0.15rem;
		color: var(--sl-color-text);
		font-size: var(--sl-text-sm);
		line-height: 1.35;
		text-decoration: none;
	}

	.mobile-sidebar-section a:hover,
	.mobile-sidebar-section a:focus {
		color: var(--sl-color-accent);
	}

	.mobile-sidebar-section a[aria-current="page"] {
		color: var(--sl-color-accent);
		font-weight: 700;
	}

	.mobile-sidebar-section a[aria-current="page"]::after {
		content: "";
		flex: 0 0 auto;
		width: 0.65rem;
		height: 0.65rem;
		background: currentColor;
	}
}
</style>
