---
import DefaultHead from "@astrojs/starlight/components/Head.astro";
import { ClientRouter } from "astro:transitions";
---

<DefaultHead />
<ClientRouter />

<script>
  (() => {
    const dynamicTransitionAttribute = "data-dynamic-page-transition";

    function normalizeRoute(value: string) {
      let route = value.trim();
      try {
        route = decodeURI(route);
      } catch {}
      return route
        .replace(/^https?:\/\/[^/]+/i, "")
        .split("#")[0]
        .split("?")[0]
        .replace(/^\/+|\/+$/g, "")
        .toLowerCase();
    }

    function compactHash(value: string) {
      let hash = 5381;
      for (let index = 0; index < value.length; index += 1) {
        hash = (hash * 33) ^ value.charCodeAt(index);
      }
      return (hash >>> 0).toString(36);
    }

    function transitionNameForPath(path: string) {
      const route = normalizeRoute(path) || "home";
      return `page-${compactHash(route)}`;
    }

    function clearDynamicTransitions() {
      document.querySelectorAll(`[${dynamicTransitionAttribute}]`).forEach((element) => {
        (element as HTMLElement).style.viewTransitionName = "";
        element.removeAttribute(dynamicTransitionAttribute);
      });
    }

    function transitionSourceForLink(link: HTMLAnchorElement) {
      const candidates = [
        link.closest(".section-index-item h2"),
        link.closest(".home-timeline-title"),
        link.closest(".home-list-item"),
        link.closest(".flat-sidebar-list a"),
        link.closest(".top-nav-links a"),
        link.closest(".mobile-nav-popover a"),
        link,
      ].filter(Boolean) as HTMLElement[];

      return (
        candidates.find((element) => getComputedStyle(element).viewTransitionName !== "none") ||
        candidates[0] ||
        (link.closest(".section-index-item h2") as HTMLElement) ||
        (link.closest(".home-timeline-title") as HTMLElement) ||
        (link.closest(".home-list-item") as HTMLElement) ||
        (link.closest(".flat-sidebar-list a") as HTMLElement) ||
        (link.closest(".top-nav-links a") as HTMLElement) ||
        (link.closest(".mobile-nav-popover a") as HTMLElement) ||
        link
      );
    }

    document.addEventListener(
      "click",
      (event: MouseEvent) => {
        if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
          return;
        }

        const link = event.target instanceof Element ? (event.target.closest("a[href]") as HTMLAnchorElement | null) : null;
        if (!link) return;

        const url = new URL(link.href, location.href);
        if (url.origin !== location.origin || url.pathname === location.pathname && url.hash) return;

        clearDynamicTransitions();
        const source = transitionSourceForLink(link);
        if (source) {
          source.style.viewTransitionName = transitionNameForPath(url.pathname);
          source.setAttribute(dynamicTransitionAttribute, "");
        }
      },
      { capture: true }
    );

    document.addEventListener("astro:after-swap", clearDynamicTransitions);
  })();
</script>
